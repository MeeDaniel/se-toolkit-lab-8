{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "coder-model",
      "provider": "custom",
      "maxTokens": 8192,
      "contextWindowTokens": 65536,
      "temperature": 0.1,
      "maxToolIterations": 40,
      "reasoningEffort": null
    }
  },
  "providers": {
    "custom": {
      "apiKey": "${LLM_API_KEY}",
      "apiBase": "http://qwen-code-api:8080/v1",
      "extraHeaders": null
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": ["-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://backend:8000",
          "NANOBOT_LMS_API_KEY": "${LMS_API_KEY}"
        }
      }
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "webchat": {
      "enabled": true,
      "allow_from": ["*"]
    }
  }
}
